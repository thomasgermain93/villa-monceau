{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"palette": [
				{
					"slug": "dark",
					"color": "#16323C",
					"name": "Vert sapin profond"
				},
				{
					"slug": "gold",
					"color": "#CEA77C",
					"name": "Or champagne"
				},
				{
					"slug": "cream",
					"color": "#F5EFE6",
					"name": "Crème"
				},
				{
					"slug": "white",
					"color": "#FFFFFF",
					"name": "Blanc"
				},
				{
					"slug": "black",
					"color": "#0F0F0F",
					"name": "Noir"
				},
				{
					"slug": "gold-muted",
					"color": "#B8935E",
					"name": "Or foncé"
				}
			],
			"gradients": [],
			"duotone": []
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "'Cormorant Garamond', Georgia, serif",
					"slug": "display",
					"name": "Cormorant Garamond",
					"fontFace": [
						{
							"fontFamily": "Cormorant Garamond",
							"fontWeight": "300 700",
							"fontStyle": "normal italic",
							"src": [
								"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap"
							]
						}
					]
				},
				{
					"fontFamily": "'DM Sans', 'Helvetica Neue', sans-serif",
					"slug": "body",
					"name": "DM Sans"
				}
			],
			"fontSizes": [
				{
					"slug": "xs",
					"size": "0.75rem",
					"name": "XS"
				},
				{
					"slug": "sm",
					"size": "0.875rem",
					"name": "SM"
				},
				{
					"slug": "base",
					"size": "1rem",
					"name": "Base"
				},
				{
					"slug": "md",
					"size": "1.125rem",
					"name": "MD"
				},
				{
					"slug": "lg",
					"size": "1.5rem",
					"name": "LG"
				},
				{
					"slug": "xl",
					"size": "2rem",
					"name": "XL"
				},
				{
					"slug": "2xl",
					"size": "3rem",
					"name": "2XL"
				},
				{
					"slug": "3xl",
					"size": "4.5rem",
					"name": "3XL"
				},
				{
					"slug": "hero",
					"size": "clamp(3.5rem, 8vw, 7rem)",
					"name": "Hero"
				}
			]
		},
		"spacing": {
			"spacingScale": {
				"operator": "*",
				"increment": 1.5,
				"steps": 7,
				"mediumStep": 1.5,
				"unit": "rem"
			},
			"spacingSizes": [
				{
					"slug": "20",
					"size": "1.25rem",
					"name": "20"
				},
				{
					"slug": "40",
					"size": "2.5rem",
					"name": "40"
				},
				{
					"slug": "60",
					"size": "3.75rem",
					"name": "60"
				},
				{
					"slug": "80",
					"size": "5rem",
					"name": "80"
				},
				{
					"slug": "100",
					"size": "7.5rem",
					"name": "100"
				},
				{
					"slug": "120",
					"size": "10rem",
					"name": "120"
				}
			]
		},
		"layout": {
			"contentSize": "760px",
			"wideSize": "1280px"
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontFamily": true,
					"fontSize": true,
					"letterSpacing": true
				}
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--cream)",
			"text": "var(--wp--preset--color--black)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--base)",
			"lineHeight": "1.7",
			"fontWeight": "300"
		},
		"spacing": {
			"blockGap": "0",
			"padding": {
				"top": "0px",
				"bottom": "0px",
				"right": "var(--wp--preset--spacing--40)",
				"left": "var(--wp--preset--spacing--40)"
			}
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontSize": "var(--wp--preset--font-size--hero)",
					"fontWeight": "400",
					"lineHeight": "1.1",
					"letterSpacing": "-0.02em"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontSize": "var(--wp--preset--font-size--3xl)",
					"fontWeight": "400",
					"lineHeight": "1.15",
					"letterSpacing": "-0.01em"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontSize": "var(--wp--preset--font-size--xl)",
					"fontWeight": "400",
					"lineHeight": "1.2"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--dark)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--gold)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--gold)",
					"text": "var(--wp--preset--color--white)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontSize": "var(--wp--preset--font-size--xs)",
					"fontWeight": "500",
					"letterSpacing": "0.15em",
					"textTransform": "uppercase"
				},
				"border": {
					"radius": "0"
				},
				"spacing": {
					"padding": {
						"top": "0.9rem",
						"bottom": "0.9rem",
						"left": "2rem",
						"right": "2rem"
					}
				}
			}
		},
		"blocks": {
			"core/button": {
				"color": {
					"background": "transparent",
					"text": "#CEA77C"
				},
				"border": {
					"radius": "0",
					"width": "1px",
					"style": "solid",
					"color": "rgba(206,167,124,0.4)"
				},
				"typography": {
					"fontSize": "0.65rem",
					"letterSpacing": "0.15em",
					"textTransform": "uppercase"
				},
				"spacing": {
					"padding": {
						"top": "0.8rem",
						"bottom": "0.8rem",
						"left": "1.8rem",
						"right": "1.8rem"
					}
				},
				"css": "& .wp-block-button__link { transition: all 0.2s; } & .wp-block-button__link:hover { background: #CEA77C !important; color: #FFFFFF !important; }"
			}
		}
	},
	"customTemplates": [
		{
			"name": "front-page",
			"title": "Page d'accueil",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "single-chambre",
			"title": "Chambre (détail)",
			"postTypes": [
				"chambre"
			]
		},
		{
			"name": "archive-chambre",
			"title": "Chambres (liste)",
			"postTypes": [
				"chambre"
			]
		},
		{
			"name": "page-contact",
			"title": "Contact",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "page-legal",
			"title": "Page légale",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "page-mentions-legales",
			"title": "Mentions légales",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "page-politique-de-confidentialite",
			"title": "Politique de confidentialité",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "page-politique-de-cookies",
			"title": "Politique de cookies",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "archive-chorale",
			"title": "Chorales (liste)",
			"postTypes": [
				"chorale"
			]
		},
		{
			"name": "single-chorale",
			"title": "Chorale (détail)",
			"postTypes": [
				"chorale"
			]
		}
	],
	"templateParts": [
		{
			"name": "header",
			"title": "En-tête",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Pied de page",
			"area": "footer"
		}
	]
}